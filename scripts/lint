#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="${GOBIN:-${ROOT}/.bin}"
GO_CACHE_DIR="${GOCACHE:-${ROOT}/.cache/go-build}"
GO_TMP_DIR="${GOTMPDIR:-${ROOT}/.cache/tmp}"
LINT_BIN="${BIN_DIR}/golangci-lint"

mkdir -p "${GO_CACHE_DIR}" "${GO_TMP_DIR}"

if [[ ! -x "${LINT_BIN}" ]]; then
  "${ROOT}/scripts/bootstrap"
fi

cd "${ROOT}"
GOCACHE="${GO_CACHE_DIR}" GOTMPDIR="${GO_TMP_DIR}" "${LINT_BIN}" run ./...
